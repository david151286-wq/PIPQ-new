rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Qualquer pessoa pode LER o calendário, os horários e as
    // sociedades — é o que faz o site mostrar essas informações
    // para quem visita, mesmo sem fazer login.
    //
    // Só um usuário AUTENTICADO (ou seja, logado como admin pelo
    // próprio site) pode CRIAR, EDITAR ou EXCLUIR esses dados.

    match /eventos/{eventoId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /horarios/{horarioId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /sociedades/{sociedadeId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /sociedades_agenda/{atividadeId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /pagina_sobre/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /temas/{temaId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /pipqtv/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /membros/{membroId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /escalas/{escalaId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
